{
  "name": "seating-chart-web-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,client -c cyan,magenta \"tsx watch server/index.ts\" \"vite --host 0.0.0.0\"",
    "build": "tsc --noEmit && vite build",
    "start": "NODE_ENV=production tsx server/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "exceljs": "4.4.0",
    "express": "5.2.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "socket.io": "4.8.3",
    "socket.io-client": "4.8.3",
    "tsx": "4.21.0"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "concurrently": "9.2.1",
    "typescript": "5.9.3",
    "vite": "6.4.2",
    "vitest": "3.2.4"
  }
}
